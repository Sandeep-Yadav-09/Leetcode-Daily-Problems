# Approach 2:
class Solution:
    def minJumps(self, arr: List[int]) -> int:
        n = len(arr)

        mp = defaultdict(list)

        for i in range(n):
            mp[arr[i]].append(i)

        que = deque([(0, 0)])
        visit = set([0])

        while que:
            node, dis = que.popleft()

            if node == n - 1:
                return dis

            if node - 1 >= 0 and node - 1 not in visit:
                visit.add(node - 1)
                que.append((node - 1, dis + 1))

            if node + 1 < n and node + 1 not in visit:
                visit.add(node + 1)
                que.append((node + 1, dis + 1))

            for nei in mp[arr[node]]:
                if nei not in visit:
                    visit.add(nei)
                    que.append((nei, dis + 1))

            mp[arr[node]].clear()
