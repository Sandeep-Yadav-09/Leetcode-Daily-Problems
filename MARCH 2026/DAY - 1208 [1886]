** 1886. Determine Whether Matrix Can Be Obtained By Rotation **

# Approach 1:
class Solution:
    def findRotation(self, mat: List[List[int]], target: List[List[int]]) -> bool:
        def rotate(matrix):
            n = len(matrix)
            for i in range(n):
                for j in range(i, n):
                    matrix[i][j], matrix[j][i] = matrix[j][i], matrix[i][j]
            for i in matrix:
                i.reverse()
        for i in range(4):
            if mat == target:
                return True
            rotate(mat)
        return False

# Approach 2:
class Solution:
    def findRotation(self, mat: List[List[int]], target: List[List[int]]) -> bool:
        n = len(mat)
        possible = [True, True, True, True]
        
        for i in range(n):
            for j in range(n):
                if mat[i][j] != target[i][j]:
                    possible[0] = False
                
                if mat[i][j] != target[j][n-1-i]:
                    possible[1] = False
                
                if mat[i][j] != target[n-1-i][n-1-j]:
                    possible[2] = False
                
                if mat[i][j] != target[n-1-j][i]:
                    possible[3] = False
                
                if not any(possible):
                    return False
        
        return any(possible)
