** 2144. Minimum Cost of Buying Candies With Discount **

# Approach 1:
class Solution:
    def minimumCost(self, cost: List[int]) -> int:
        n = len(cost)
        cost.sort(reverse=True)
        ans = 0
        for i in range(n):
            if i % 3 == 2:
                continue
            ans += cost[i]
        return ans 

# Approach 2:
class Solution:
    def minimumCost(self, cost: List[int]) -> int:
        cost.sort(reverse = True)
        ans = 0
        N = len(cost)
        pres_candy = 0
        count = 0
        if N > 2:
            for i in range(N):
                if count == 2 and pres_candy >= cost[i]:
                    count = 0
                    pres_candy = 0
                else:
                    pres_candy = cost[i] + pres_candy
                    ans = ans + cost[i]
                    count += 1
        else:
            return sum(cost)
        return ans
